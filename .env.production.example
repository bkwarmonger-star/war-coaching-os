# W.A.R. Coaching OS - Production Environment Template
# Copy this file to .env.production and fill in your values

# ============================================================================
# REQUIRED: Core Configuration
# ============================================================================

# Node environment (must be 'production' for production deployment)
NODE_ENV=production

# Server port (default: 3000)
PORT=3000

# ============================================================================
# REQUIRED: Database
# ============================================================================

# MySQL connection string (Drizzle ORM format)
# Format: mysql://username:password@host:port/database
# Example: mysql://root:mypassword@localhost:3306/war_coaching
DATABASE_URL=mysql://user:password@host:3306/database_name

# ============================================================================
# REQUIRED: Authentication & OAuth
# ============================================================================

# OAuth server URL (Manus or your OAuth provider)
# Example: https://oauth.manus.space
OAUTH_SERVER_URL=https://your-oauth-server.com

# JWT secret for cookie signing (use a secure random string)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-generate-random

# Owner's OpenID (your unique OAuth identifier)
# This is your personal OAuth ID from Manus
OWNER_OPEN_ID=your-owner-open-id-here

# App ID from OAuth provider
VITE_APP_ID=your-app-id-here

# ============================================================================
# REQUIRED: LLM / AI Services
# ============================================================================

# Forge API endpoint (for AI exercise/nutrition generation)
# Example: https://api.forge.example.com or https://api.openai.com
BUILT_IN_FORGE_API_URL=https://your-llm-api.com

# Forge API key (authenticate to LLM service)
# Keep this secret! Store in secure vault
BUILT_IN_FORGE_API_KEY=sk-your-api-key-here

# ============================================================================
# OPTIONAL: Error Tracking & Monitoring
# ============================================================================

# Sentry DSN for backend error tracking
# Get from: https://sentry.io
# Leave empty to disable
SENTRY_DSN=https://your-sentry-key@sentry.io/1234567

# Sentry DSN for frontend (client-side) error tracking
# Same as above but for the browser client
VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/1234567

# ============================================================================
# OPTIONAL: Analytics
# ============================================================================

# Analytics endpoint (Umami, Plausible, etc.)
# Leave empty to disable
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com

# Analytics website ID (specific to your analytics platform)
VITE_ANALYTICS_WEBSITE_ID=

# ============================================================================
# OPTIONAL: Storage / S3 Configuration
# (Usually handled by storage proxy, but can be customized)
# ============================================================================

# AWS S3 Bucket (if using S3 for photo storage)
# AWS_S3_BUCKET=your-bucket-name
# AWS_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# ============================================================================
# OPTIONAL: Stripe (for payments)
# ============================================================================

# Stripe API key (keep secret!)
# STRIPE_API_KEY=sk_live_your_key_here

# Stripe webhook secret
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================================================
# OPTIONAL: Email / Notifications
# ============================================================================

# Email service (e.g., SendGrid, AWS SES)
# SENDGRID_API_KEY=SG.your_key_here
# SENDGRID_FROM_EMAIL=noreply@warcoachos.com

# ============================================================================
# Notes
# ============================================================================

# 1. Never commit this file to git with real values
# 2. Use a secrets management system (AWS Secrets Manager, Vault, etc.)
# 3. Rotate API keys regularly
# 4. Use different keys for staging vs production
# 5. Enable HTTPS in production
# 6. Set up monitoring and alerting for all critical services
