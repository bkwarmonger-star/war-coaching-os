# W.A.R. Coaching OS — Production Environment
# Copy to .env.production and fill in your values.
# Never commit the filled-in file.

# ── REQUIRED ────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# MySQL — from your host (PlanetScale, Railway, Render, etc.)
DATABASE_URL=mysql://user:password@host:3306/war_coaching

# Auth — generate with: openssl rand -base64 64
JWT_SECRET=

# LLM — OpenAI key (or any OpenAI-compatible provider)
LLM_API_KEY=sk-...
# Override if using a different provider (default: https://api.openai.com)
# LLM_API_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini

# S3 — IAM user needs s3:PutObject + s3:GetObject on your bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# ── POST-DEPLOY ──────────────────────────────────────────────────────────────
# Set these after your first deploy once you have a live URL

# Set to local:<your-email> after your first signup to claim trainer ownership
# OWNER_OPEN_ID=local:you@example.com

# Stripe — get live keys after deploy; webhook secret requires your live URL
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Email — pick one provider
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG...
# POSTMARK_SERVER_TOKEN=...
# EMAIL_FROM=noreply@yourdomain.com

# OAuth (not required — email+password auth works without it)
# OAUTH_SERVER_URL=
# VITE_APP_ID=
